{
  "name": "chirping-tmp",
  "version": "0.1.0",
  "type": "module",
  "description": "A Chirpy-inspired, single-template, multilingual Astro v6 theme with Tailwind v4, daisyUI, MDX, Pagefind, and Giscus.",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && npm run pagefind",
    "preview": "astro preview",
    "serve": "npm run build && npm run preview",
    "astro": "astro",
    "pagefind": "pagefind --site dist --output-subdir _pagefind",
    "postbuild": "echo \"Pagefind index generated in dist/_pagefind\"",
    "typecheck": "astro check",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{astro,ts,tsx,js,jsx,md,mdx,css,json}\"",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,jsx,md,mdx,css,json}\""
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.3.1",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.18.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/lato": "5.2.7",
    "@fontsource/source-sans-3": "5.2.9",
    "@iconify-json/lucide": "^1.2.106",
    "@iconify-json/simple-icons": "^1.2.81",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "daisyui": "^5.5.19",
    "eslint": "^9.18.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "katex": "^0.16.45",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "satori": "^0.26.0",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.60.3",
    "@rollup/rollup-linux-x64-gnu": "4.60.3",
    "@img/sharp-darwin-arm64": "0.34.5",
    "@img/sharp-linux-x64": "0.34.5"
  },
  "keywords": [
    "astro",
    "astro-theme",
    "chirpy",
    "tailwindcss",
    "daisyui",
    "mdx",
    "pagefind",
    "giscus",
    "i18n",
    "blog"
  ]
}
