---
import { SITE, type Locale } from '../config';
import { formatDate, isoDate } from '../i18n/utils';
import { type Post, postPath, heroImage } from '../utils/posts';
import SmartImage from './SmartImage.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  post: Post;
  locale: Locale;
  prioritizeLcp?: boolean;
}

const { post, locale, prioritizeLcp = false } = Astro.props;
const href = postPath(post);
const heroAsset = heroImage(post);
// Whether featured images are enabled (per-post override → site default).
// When enabled we always reserve the thumbnail column so every card shares
// the same layout — posts without a `heroImage` get a placeholder instead.
const featuredEnabled = post.data.showFeaturedImage ?? SITE.showFeaturedImages;
const showThumb = featuredEnabled;
const hasImage = Boolean(heroAsset) && featuredEnabled;
const heroAlt = post.data.heroImageAlt ?? '';
const isDynamicCardHeight = post.data.dynamicPostCardHeight ?? SITE.dynamicPostCardHeight;
---

<article class="chirpy-card">
  <a
    href={href}
    class:list={[
      'chirpy-card-link',
      showThumb ? 'has-image' : 'no-image',
      isDynamicCardHeight ? 'dynamic-size' : 'fixed-size',
    ]}
  >
    {
      showThumb && (
        <div class="chirpy-card-image-wrap">
          {hasImage ? (
            <SmartImage
              src={heroAsset!}
              alt={heroAlt}
              class="chirpy-card-image"
              loading={prioritizeLcp ? 'eager' : 'lazy'}
              fetchpriority={prioritizeLcp ? 'high' : 'auto'}
              widths={[384, 768, 960]}
              sizes="(max-width: 767px) 100vw, 378px"
              quality={75}
            />
          ) : (
            <div class="chirpy-card-image chirpy-card-placeholder" aria-hidden="true">
              <Icon name="lucide:image" width={40} height={40} />
            </div>
          )}
        </div>
      )
    }

    <div class:list={['chirpy-card-body', showThumb ? '' : 'full']}>
      <h2 class:list={['chirpy-card-title', showThumb ? '' : 'compact']}>
        {post.data.title}
      </h2>

      <p
        class:list={[
          'text-base-content/70 text-base',
          showThumb ? 'mt-2 mb-3 line-clamp-2' : 'mt-1 mb-2 line-clamp-3',
        ]}
      >
        {post.data.description}
      </p>

      <div class="text-base-content/70 mt-3 flex items-end justify-between gap-2 text-xs">
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
          <span class="inline-flex items-center gap-1">
            <Icon name="lucide:clock" width={12} height={12} />
            <time datetime={isoDate(post.data.pubDate)}>
              {
                formatDate(post.data.pubDate, locale, {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })
              }
            </time>
          </span>
          {
            post.data.categories.length > 0 && (
              <span class="inline-flex items-center gap-1">
                <Icon name="lucide:folder" width={12} height={12} />
                <span>{post.data.categories.join(', ')}</span>
              </span>
            )
          }
        </div>

        {
          post.data.pinned && (
            <span
              class="text-primary inline-flex items-center gap-1"
              title="Pinned"
              aria-label="Pinned"
            >
              <Icon name="lucide:pin" width={14} height={14} />
            </span>
          )
        }
      </div>
    </div>
  </a>
</article>
